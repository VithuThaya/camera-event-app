# Supabase project: camera-event-app (eu-central-1)
# Dashboard: https://supabase.com/dashboard/project/hfhxgnmdhgkglamcwwij

# Every value here is server-only on purpose. The browser never talks to
# Supabase directly, so no NEXT_PUBLIC_* Supabase key exists and none should
# be added — that is what keeps the anon key out of the client bundle.

SUPABASE_URL=https://your-project.supabase.co

# service_role bypasses RLS. Treat it like a database password.
# Dashboard -> Project Settings -> API Keys -> service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# Signs guest and host session cookies. At least 32 chars.
# Generate: node -e "console.log(require('node:crypto').randomBytes(48).toString('base64url'))"
# Rotating this logs every guest out and resets their upload quota, so pick
# one before the event and leave it alone.
SESSION_SECRET=

# Public origin used to build the QR/join links shown to the host. Set this in
# production, where the origin is fixed and known.
#
# Leave it unset locally. Both callers fall back to window.location.origin, so
# the QR encodes whatever host the browser is actually on — which is what you
# want behind a tunnel, since a Cloudflare quick tunnel hands out a fresh URL on
# every restart and pinning it here means editing this file each time. Set to
# localhost and the QR points a guest's phone at the guest's own phone.
# NEXT_PUBLIC_APP_URL=https://your-domain.example

# Guards /api/cron/retention, which deletes expired events. Vercel generates
# this for you when a cron is configured and attaches it as a Bearer token; set
# it yourself only for local testing. The route refuses to run at all when this
# is unset, so a deploy that forgets it stops deleting rather than starts
# deleting for anyone who finds the URL.
# Generate: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET=

# Only used by scripts/verify-rls.mjs to prove RLS blocks anon access.
# The app itself never reads this.
SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Note for this machine (not an app setting, and not read from this file):
#
# Something on this Mac inspects TLS, and Node ships its own CA list rather
# than using the macOS keychain — so `fetch` fails with "unable to get local
# issuer certificate" while curl works fine. supabase-js is built on fetch, so
# the dev server cannot reach Supabase at all until Node is pointed at the
# same CA bundle npm already uses:
#
#   export NODE_EXTRA_CA_CERTS="$HOME/.config/npm-certs.pem"
#
# Add that to ~/.zshrc. Vercel has no such proxy and needs nothing.
# ---------------------------------------------------------------------------
